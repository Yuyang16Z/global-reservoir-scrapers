__pycache__/
*.py[cod]
.venv/
venv/
env/
.idea/
.vscode/
.DS_Store
*.log
.env

# local dev output dirs (real outputs live under data/<country>/)
scrapers/*/*_outputs/
scrapers/*/*/*_outputs/

# China MWR: skip heavy binary artefacts from the OCR pipeline
# (regenerable — keep them on the Oracle VM, not in the repo)
data/china/mwr/*/screens/
data/china/mwr/*/recover_failed/
data/china/mwr/*/ocr_json/
data/china/mwr/*.lock
data/china/mwr/.grab_data.lock

# South Africa DWS: raw PDFs are an idempotency cache (~800KB each, 100+
# per year). Keep on local checkout / runner only; redownload-on-demand.
data/southafrica/dws_weekly/pdfs/
