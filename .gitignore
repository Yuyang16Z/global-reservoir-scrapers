__pycache__/
*.py[cod]
.venv/
venv/
env/
.idea/
.vscode/
.DS_Store
*.log
.env

# local dev output dirs (real outputs live under data/<country>/)
scrapers/*/*_outputs/
scrapers/*/*/*_outputs/

# China MWR: the legacy OCR path is retired. New collection writes only to
# data/china/mwr_api/. Keep the historical OCR archive compact and read-only.
data/china/mwr/
data/china/mwr_ocr_archive/*/screens/
data/china/mwr_ocr_archive/*/recover_failed/
data/china/mwr_ocr_archive/*/ocr_json/
data/china/mwr_ocr_archive/*.lock
data/china/mwr_ocr_archive/.grab_data.lock

# South Africa DWS: raw PDFs are an idempotency cache (~800KB each, 100+
# per year). Keep on local checkout / runner only; redownload-on-demand.
data/southafrica/dws_weekly/pdfs/
